# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/market_intelligence

# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# AI Model Configuration
# Supported models: gemini-2.5-flash (default), gemini-1.5-pro, gemini-1.5-flash
AI_MODEL=gemini-2.5-flash

# Server Configuration
PORT=3000
NODE_ENV=development
