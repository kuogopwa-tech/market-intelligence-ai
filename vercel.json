{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/deriv-analyst/dist/public",

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,

  "crons": [
    {
      "path": "/api/scanner/cron",
      "schedule": "*/5 * * * *"
    }
  ]
}