{
  "version": 2,
  "framework": null,
  "installCommand": "corepack enable && corepack prepare pnpm@10.34.1 --activate && pnpm install --frozen-lockfile",

  "builds": [
    {
      "src": "artifacts/api-server/dist/index.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}