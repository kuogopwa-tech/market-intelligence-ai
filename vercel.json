{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/deriv-analyst/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}