{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/deriv-analyst/dist/public",

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],

  "crons": [
    {
      "path": "/api/scanner/cron",
      "schedule": "*/5 * * * *"
    }
  ]
}