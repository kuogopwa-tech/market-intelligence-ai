{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/deriv-analyst/dist/public",
  "installCommand": "pnpm install",
  "builds": [
    { "src": "artifacts/api-server/dist/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "artifacts/api-server/dist/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}